# 复制为 .env（已被 gitignore）。密钥只在服务端，勿提交。

# D014 DeepSeek
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
# OpenAI 兼容根路径需含 /v1。缺省时会自动补 /v1。
# 官方：https://api.deepseek.com/v1
# 第三方代理示例：https://api.b.ai/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# stub | model（默认：有密钥则 model，否则 stub）
# SANDTABLE_AGENT_MODE=stub

# SANDTABLE_LLM_TIMEOUT_MS=60000
# SANDTABLE_DB_PATH=data/sandtable.sqlite

# 推演限流在代码默认 30 次/分钟/IP；测试可注入 deduceRateLimit: 0
